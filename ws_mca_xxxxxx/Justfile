# =============================================================================
# PROJECT CONFIGURATION
# =============================================================================

set shell := ["bash", "-c"]
set dotenv-load := true

# Docker image naming
PROJECT_USER    := "kaybenleroll"
PROJECT_NAME    := "ws_mca_202605"
PROJECT_TAG     := "latest"
IMAGE_TAG       := PROJECT_USER + "/" + PROJECT_NAME + ":" + PROJECT_TAG

# RStudio Server credentials
DOCKER_USER     := "rstudio"
DOCKER_PASS     := env_var_or_default("DOCKER_PASS", "CHANGEME")

# User/group mapping for file permissions in container
DOCKER_UID      := `id -u`
DOCKER_GID      := `id -g`

# Directory configuration
PWD             := `pwd`
RSTUDIO_PORT    := env_var_or_default("RSTUDIO_PORT", "8791")

PROJECT_FOLDER  := "mca_workshop"
CONTAINER_NAME  := "mca-workshop"

# Build and logging configuration
OUTPUT_LOG      := "quarto_render_output.log"
DOCKER_BUILD_ARGS := ""

# =============================================================================
# DEFAULT TARGET
# =============================================================================

default:
  @just --list

# =============================================================================
# RENDERING TARGETS
# =============================================================================

all: part1 part2

_needs_rebuild output *sources:
  #!/usr/bin/env bash
  mkdir -p .just-cache
  combined_hash=$(cat {{sources}} 2>/dev/null | md5sum | cut -d' ' -f1)
  cache_file=".just-cache/$(basename {{output}}).md5"
  if [ ! -f {{output}} ] || 
     [ ! -f "$cache_file" ] || 
     [ "$combined_hash" != "$(cat $cache_file 2>/dev/null)" ]; then
    echo "REBUILD_NEEDED"
  else
    echo "UP_TO_DATE"
  fi

_render-qmd-container-internal qmd_file:
  #!/usr/bin/env bash
  qmd_file="{{qmd_file}}"
  quarto render "$qmd_file" --to html

_render-qmd-host-orchestrated qmd_file:
  #!/usr/bin/env bash
  set -euo pipefail
  qmd_file="{{qmd_file}}"
  html_file="${qmd_file%.qmd}.html"
  all_deps="$qmd_file lib_utils.R"
  REBUILD_STATUS="$(just _needs_rebuild "$html_file" $all_deps)"
  if [ "$REBUILD_STATUS" = "REBUILD_NEEDED" ]; then
    echo "TIMESTAMP: $(date) - Rendering $qmd_file" >> {{OUTPUT_LOG}} 2>&1
    if ! podman exec -u {{DOCKER_USER}} -w /home/rstudio/{{PROJECT_FOLDER}} {{CONTAINER_NAME}} \
      just _render-qmd-container-internal "$qmd_file" >> {{OUTPUT_LOG}} 2>&1; then
      echo "TIMESTAMP: $(date) - FAILED $qmd_file" >> {{OUTPUT_LOG}} 2>&1
      exit 1
    fi
    echo "TIMESTAMP: $(date) - Finished $qmd_file" >> {{OUTPUT_LOG}} 2>&1
    combined_hash=$(cat $qmd_file lib_utils.R 2>/dev/null | md5sum | cut -d' ' -f1)
    cache_file=".just-cache/$(basename $html_file).md5"
    echo "$combined_hash" > "$cache_file"
  else
    echo "TIMESTAMP: $(date) - $qmd_file is $REBUILD_STATUS" >> {{OUTPUT_LOG}} 2>&1
  fi

part1: _ensure-container-running
  #!/usr/bin/env bash
  set -euo pipefail
  echo "▶ Rendering MCA Part 1..."
  just _render-qmd-host-orchestrated ws_mca_part1_foundations.qmd
  if [ -f ws_mca_part1_foundations.html ]; then \
    echo "✓ Part 1 complete"; \
  else \
    echo "✗ Part 1 failed: ws_mca_part1_foundations.html not found"; \
    exit 1; \
  fi

part2: _ensure-container-running
  #!/usr/bin/env bash
  set -euo pipefail
  echo "▶ Rendering MCA Part 2..."
  just _render-qmd-host-orchestrated ws_mca_part2_real_data_and_advanced.qmd
  if [ -f ws_mca_part2_real_data_and_advanced.html ]; then \
    echo "✓ Part 2 complete"; \
  else \
    echo "✗ Part 2 failed: ws_mca_part2_real_data_and_advanced.html not found"; \
    exit 1; \
  fi

basics: part1 part2

_ensure-container-running:
  @if [ "$(just _is-container-running)" != "true" ]; then \
    echo "Container not running. Stopping and removing any old container, then starting a new one..."; \
    just podman-stop-image; \
    just podman-rm; \
    just podman-run-image; \
    sleep 5; \
  else \
    echo "Container already running. Reusing existing container..."; \
  fi

# Container Rendering
render-container file:
  #!/usr/bin/env bash
  qmd="{{file}}"
  if [[ "$qmd" != *.qmd ]]; then qmd="${qmd}.qmd"; fi
  if [ ! -f "$qmd" ]; then echo "Error: $qmd not found"; exit 1; fi
  podman exec -u {{DOCKER_USER}} -w /home/rstudio/{{PROJECT_FOLDER}} {{CONTAINER_NAME}} \
    quarto render "$qmd" --to html

render-container-all:
  @just render-container ws_mca_part1_foundations
  @just render-container ws_mca_part2_real_data_and_advanced

_is-container-running:
  @podman ps --filter "name={{CONTAINER_NAME}}" --format "{{{{.Status}}}}" | grep -q "Up" && echo "true" || echo "false"

# =============================================================================
# PODMAN TARGETS
# =============================================================================

podman-build-image:
  podman build -t {{IMAGE_TAG}} \
    --build-arg BUILD_DATE=`date -u +'%Y-%m-%dT%H:%M:%SZ'` \
    {{DOCKER_BUILD_ARGS}} \
    -f Dockerfile .

podman-rebuild-image:
  podman build --no-cache -t {{IMAGE_TAG}} \
    --build-arg BUILD_DATE=`date -u +'%Y-%m-%dT%H:%M:%SZ'` \
    {{DOCKER_BUILD_ARGS}} \
    -f Dockerfile .

podman-run-image:
  podman run --rm -d \
    --userns=keep-id \
    -e RUNROOTLESS=false \
    -p "127.0.0.1:{{RSTUDIO_PORT}}:8787" \
    -e USER={{DOCKER_USER}} \
    -e PASSWORD={{DOCKER_PASS}} \
    -e USERID={{DOCKER_UID}} \
    -e GROUPID={{DOCKER_GID}} \
    -v "{{PWD}}:/home/rstudio/{{PROJECT_FOLDER}}:z" \
    --name {{CONTAINER_NAME}} \
    {{IMAGE_TAG}}

podman-stop-image:
  podman stop {{CONTAINER_NAME}} || true

podman-rm: podman-stop-image
  podman rm {{CONTAINER_NAME}} || true

podman-restart: podman-stop-image
  @just podman-run-image

podman-bash:
  podman exec -u {{DOCKER_USER}} -it {{CONTAINER_NAME}} bash

# =============================================================================
# CLEANING
# =============================================================================

clean-all:
  rm -fv *.html
  rm -rf *_cache/
  rm -rf *_files/
  rm -rf .just-cache/
  rm -rfv precompute/*.parquet precompute/*.qs
  rm -fv {{OUTPUT_LOG}}
