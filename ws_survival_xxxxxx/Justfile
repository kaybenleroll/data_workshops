# Clean all generated files
clean-all: clean-html clean-cache clean-precompute clean-outputs

# Remove all HTML output files
clean-html:
  rm -fv *.html

# Remove Quarto cache and build artifacts
clean-cache:
  rm -rf *_cache/
  rm -rf *_files/
  rm -rf .just-cache/

# Remove precomputed data files (Part 1 → Part 2 workflow)
clean-precompute:
  rm -rfv precompute/*.parquet precompute/*.qs

# Remove output logs
clean-outputs:
  rm -fv {{OUTPUT_LOG}}

# Nuclear option: remove all generated, cached, and precomputed files
nuke: clean-all
  @echo "✓ All generated files removed"

# =============================================================================
# PODMAN TARGETS - Container Management
# =============================================================================
# These targets manage the Podman container lifecycle
# The container provides RStudio Server with R, Quarto, and all dependencies
# Avoids need to install R/Quarto on host machine

# Build image from Dockerfile
# Includes R packages, Quarto, and workshop dependencies
podman-build-image:
  {{CONTAINER_ENGINE}} build -t {{IMAGE_TAG}} \
    --build-arg BUILD_DATE=`date -u +'%Y-%m-%dT%H:%M:%SZ'` \
    {{PODMAN_BUILD_ARGS}} \
    -f Dockerfile . 2>&1 | tee -a docker_build.log

# Rebuild image (no cache)
# Use when Dockerfile or dependencies change significantly
podman-rebuild-image:
  {{CONTAINER_ENGINE}} build --no-cache -t {{IMAGE_TAG}} \
    --build-arg BUILD_DATE=`date -u +'%Y-%m-%dT%H:%M:%SZ'` \
    {{PODMAN_BUILD_ARGS}} \
    -f Dockerfile . 2>&1 | tee -a docker_build.log

# Run Podman container with RStudio Server
# Container configuration:
#   - Binds to localhost:8787 only (not exposed externally)
#   - Maps current directory to /home/rstudio/surv_workshop
#   - Persists GitHub Copilot auth across restarts
#   - Runs rootless with user/group ID mapping for file permissions
podman-run-image:
  {{CONTAINER_ENGINE}} run --rm -d \
    --userns=keep-id \
    -e RUNROOTLESS=false \
    -p "127.0.0.1:{{RSTUDIO_PORT}}:8787" \
    -e USER={{PODMAN_USER}} \
    -e PASSWORD={{PODMAN_PASS}} \
    -e USERID={{PODMAN_UID}} \
    -e GROUPID={{PODMAN_GID}} \
    -v "{{PWD}}:/home/rstudio/{{PROJECT_FOLDER}}:z" \
    -v "{{PWD}}/.rstudio_copilot:/home/rstudio/.config/github-copilot:rw" \
    --name {{CONTAINER_NAME}} \
    {{IMAGE_TAG}}


# Stop Podman container
podman-stop-image:
  {{CONTAINER_ENGINE}} stop {{CONTAINER_NAME}} || true

# Remove Podman container
podman-rm: podman-stop-image
  {{CONTAINER_ENGINE}} rm {{CONTAINER_NAME}} || true

# Restart Podman container
podman-restart: podman-stop-image podman-run-image

# Enter Podman container bash shell
podman-bash:
  {{CONTAINER_ENGINE}} exec -u {{PODMAN_USER}} -it {{CONTAINER_NAME}} bash

# Enter Podman container as root
podman-bash-root:
  {{CONTAINER_ENGINE}} exec -u root -it {{CONTAINER_NAME}} bash

# Show Podman container logs
podman-logs:
  {{CONTAINER_ENGINE}} logs {{CONTAINER_NAME}}

# Show Podman container status
podman-status:
  {{CONTAINER_ENGINE}} ps -a --filter name={{CONTAINER_NAME}}

# Complete Podman cleanup
podman-clean: podman-rm
  @echo "Podman container removed"

# Display SSH tunnel command for remote RStudio access
ssh-tunnel:
  @echo "Run this command on your local machine:"
  @echo "  ssh -L {{RSTUDIO_PORT}}:localhost:{{RSTUDIO_PORT}} $(whoami)@$(hostname)"
  @echo ""
  @echo "Then access RStudio at: http://localhost:{{RSTUDIO_PORT}}"

