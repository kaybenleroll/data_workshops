# Project configuration
PROJECT_USER      := "kaybenleroll"
PROJECT_NAME      := "bm-talk-survival"
PROJECT_TAG       := "latest"
IMAGE_TAG         := PROJECT_USER + "/" + PROJECT_NAME + ":" + PROJECT_TAG
PODMAN_USER       := "rstudio"
PODMAN_PASS       := "CHANGEME"
PODMAN_UID        := `id -u`
PODMAN_GID        := `id -g`
PWD               := `pwd`
RSTUDIO_PORT      := "8787"
PROJECT_FOLDER    := "bayes_surv"
CONTAINER_NAME    := "bayes-surv"

PODMAN_BUILD_ARGS := ""

# Container runtime
PODMAN := "podman"

# List available recipes
default:
	@just --list

# ============================================================================
# Presentation Rendering
# ============================================================================

# Render Bayesian Survival Analysis presentation via Quarto
render-talk:
	@echo "TIMESTAMP: $(date) - Rendering bayesian_survival_talk.qmd"
	quarto render bayesian_survival_talk.qmd --to revealjs
	@echo "TIMESTAMP: $(date) - Finished rendering"

# Convert presentation to PDF using decktape inside a container
pdf-talk:
	@echo "Using {{PODMAN}}"
	{{PODMAN}} run --rm -t \
	  --userns=keep-id \
	  -v "{{PWD}}:/slides:Z" \
	  astefanutti/decktape:3.12.0 \
	  --size 1920x1080 \
	  /slides/bayesian_survival_talk.html \
	  /slides/bayesian_survival_talk.pdf

# Full workflow: render presentation and create PDF
all: render-talk pdf-talk

# ============================================================================
# Cleaning
# ============================================================================

# Clean Stan model files
clean-models:
	rm -fv stan_model/*.qs

# Clean generated HTML presentations
clean-html:
	rm -fv bayesian_survival_talk.html
	rm -rfv bayesian_survival_talk_files

# Clean generated PDFs
clean-pdfs:
	rm -fv bayesian_survival_talk.pdf

# Clean all generated files
clean-all: clean-html clean-pdfs clean-models

# ============================================================================
# Podman Commands
# ============================================================================

# Build Podman image
podman-build:
	{{PODMAN}} build -t {{IMAGE_TAG}} \
		--build-arg BUILD_DATE=`date -u +'%Y-%m-%dT%H:%M:%SZ'` \
		{{PODMAN_BUILD_ARGS}} \
		-f Dockerfile . 2>&1 | tee -a podman_build.log

# Show Podman build context
podman-show-context:
	{{PODMAN}} build -f build/context.dockerfile -t context-image .
	{{PODMAN}} run --rm -it context-image find /tmp/build
	{{PODMAN}} rmi context-image

# Run Podman container with RStudio
podman-run:
	{{PODMAN}} run --rm -d \
	  --userns=keep-id \
	  -e RUNROOTLESS=false \
	  -p "127.0.0.1:{{RSTUDIO_PORT}}:8787" \
	  -e USER={{PODMAN_USER}} \
	  -e PASSWORD={{PODMAN_PASS}} \
	  -e USERID={{PODMAN_UID}} \
	  -e GROUPID={{PODMAN_GID}} \
	  -v "{{PWD}}:/home/rstudio/{{PROJECT_FOLDER}}:Z" \
	  -v "{{PWD}}/.rstudio_copilot:/home/rstudio/.config/github-copilot:rw" \
	  --name {{CONTAINER_NAME}} \
	  {{IMAGE_TAG}}
	@echo "RStudio Server running at http://127.0.0.1:{{RSTUDIO_PORT}}"
	@echo "Username: {{PODMAN_USER}}"
	@echo "Password: {{PODMAN_PASS}}"

# Stop Podman container
podman-stop:
	{{PODMAN}} stop {{CONTAINER_NAME}}

# Remove Podman container completely
podman-rm: podman-stop
	{{PODMAN}} rm {{CONTAINER_NAME}}

# Enter Podman container bash
podman-bash:
	{{PODMAN}} exec -u {{PODMAN_USER}} -it {{CONTAINER_NAME}} bash

# Fix Podman container permissions (if files get owned by the container user)
podman-fix-permissions:
	{{PODMAN}} unshare chown -R {{PODMAN_UID}}:{{PODMAN_GID}} "{{PWD}}"

# View Podman container logs
podman-logs:
	{{PODMAN}} logs {{CONTAINER_NAME}}

# Full Podman workflow: build, run, and show access info
podman-setup: podman-build podman-run
