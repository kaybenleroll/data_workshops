all-html: all

# Internal helper: Check if rebuild needed based on content hash
# Uses MD5 hashing to detect actual content changes (not just timestamps)
# Returns exit 0 if rebuild needed, exit 1 if up-to-date
_needs_rebuild output *sources:
	#!/usr/bin/env bash
	mkdir -p .just-cache
	
	# Combine all source files and compute MD5 hash
	# This detects actual content changes, ignoring comments/whitespace-only edits
	combined_hash=$(cat {{sources}} 2>/dev/null | md5sum | cut -d' ' -f1)
	cache_file=".just-cache/$(basename {{output}}).md5"
	
	# Rebuild if: output missing, cache missing, or hash changed
	# Three conditions that trigger a rebuild:
	#   1. HTML output doesn't exist yet
	#   2. No cached hash (first run or cache cleared)
	#   3. Source content changed (hash mismatch)
	if [ ! -f {{output}} ] || \
	   [ ! -f "$cache_file" ] || \
	   [ "$combined_hash" != "$(cat $cache_file 2>/dev/null)" ]; then
		echo "$combined_hash" > "$cache_file"
		exit 0  # needs rebuild
	else
		echo "$(basename {{output}}) is up to date (no content changes)"
		exit 1  # skip rebuild (content unchanged)
	fi

# Internal helper: Render a single QMD file with logging and hash-based caching
# Only re-renders when QMD content or dependencies (lib_utils.R) actually change
# Logs all rendering activity to OUTPUT_LOG for debugging
_render-qmd qmd_file:
	#!/usr/bin/env bash
	qmd_file="{{qmd_file}}"
	html_file="${qmd_file%.qmd}.html"
	
	# Build list of all dependencies for hash-based change detection
	# Include both the QMD file and shared R libraries that it sources
	all_deps="$qmd_file lib_utils.R"
	
	# Check if rebuild needed (based on content hash, not timestamps)
	# _needs_rebuild returns 0 if rebuild needed, 1 if up-to-date
	if just _needs_rebuild "$html_file" $all_deps; then
		# Log rendering start/end times for performance tracking
		echo "TIMESTAMP: $(date) - Rendering $qmd_file" >> {{OUTPUT_LOG}} 2>&1
		quarto render "$qmd_file" --to html >> {{OUTPUT_LOG}} 2>&1
		echo "TIMESTAMP: $(date) - Finished $qmd_file" >> {{OUTPUT_LOG}} 2>&1
	fi

# =============================================================================
# PRIMARY WORKSHOP TARGETS - Sequential Workshop Workflow
# =============================================================================
# Current workshop sequence: Part 1 (initial_survival_models) → Part 2 (expanded_coxph_models)
# To extend: Add new parts to primary array in render-container-all and update dependencies

# Render Part 1: Initial survival models and exploratory analysis
initial_survival_models:
	@echo "▶ Rendering Part 1: Initial Survival Models..."
	@mkdir -p precompute
	@just _render-qmd initial_survival_models.qmd
	@echo "✓ Part 1 complete (data saved to precompute/)"

# Render Part 2: Cox regression and advanced validation (requires Part 1)
# DEPENDENCY: Requires initial_survival_models to run first (creates precompute/ data)
# Part 2 loads models and data saved by Part 1, so strict ordering is enforced
expanded_coxph_models: initial_survival_models
	@echo "▶ Rendering Part 2: Expanded Cox PH Models..."
	# Validate that Part 1's output exists before attempting Part 2
	# Part 2 notebook will fail if it can't load precomputed data
	@if [ ! -f precompute/telco_churn_cat.parquet ]; then \
		echo "✗ Error: precompute/telco_churn_cat.parquet not found"; \
		echo "  Run 'just initial_survival_models' first to generate required files"; \
		exit 1; \
	fi
	@just _render-qmd expanded_coxph_models.qmd
	@echo "✓ Part 2 complete"

# Render current workshop sequence (all primary parts in dependency order)
workshop-sequence: initial_survival_models expanded_coxph_models
	@echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
	@echo "✓ Workshop sequence completed successfully"
	@echo "  Part 1: initial_survival_models.html"
	@echo "  Part 2: expanded_coxph_models.html"
	@echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

# Alias for workshop sequence
worksheet: workshop-sequence

