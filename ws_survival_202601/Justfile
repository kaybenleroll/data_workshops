	@find . -name "*.qmd" | xargs wc -l 2>/dev/null | tail -1 || echo "0"
	@echo -n "  .Rmd files: "
	@find . -name "*.Rmd" | xargs wc -l 2>/dev/null | tail -1 || echo "0"
	@echo ""
	@echo "Workshop notebooks:"
	@wc -l initial_survival_models.qmd expanded_coxph_models.qmd 2>/dev/null | tail -1 || echo "  Files not found"
