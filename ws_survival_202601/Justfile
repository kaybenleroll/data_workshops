# --- Container Rendering (exec inside running container) ---
# RECOMMENDED: These targets use Docker container for rendering (no host R/Quarto needed)

# Render any QMD using Quarto inside the running container
# Requires container to be running (start with: just docker-run-image)
render-container file:
	#!/usr/bin/env bash
	# Auto-append .qmd extension if not specified
	qmd="{{file}}"
	if [[ "$qmd" != *.qmd ]]; then
		qmd="${qmd}.qmd"
	fi
	# Validate file exists on host before sending to container
	if [ ! -f "$qmd" ]; then
		echo "Error: $qmd not found in host project root"
		exit 1
	fi
	# Ensure container is running before attempting exec
	if ! docker ps --format '{{"{{"}}.Names{{"}}"}}' | grep -q '^{{CONTAINER_NAME}}$'; then
		echo "Error: container {{CONTAINER_NAME}} is not running. Start it with: just docker-run-image"
		exit 1
	fi
	echo "Rendering $qmd inside container {{CONTAINER_NAME}}..."
	# Execute Quarto inside container (as rstudio user, in project directory)
	docker exec -u {{DOCKER_USER}} -w /home/rstudio/{{PROJECT_FOLDER}} {{CONTAINER_NAME}} \
		quarto render "$qmd" --to html

# Render all QMDs using Quarto inside the running container
# SMART ORDERING: Renders primary notebooks in dependency order, then supplementary notebooks
# SKIPS: temp_* experimental notebooks that may have missing data
render-container-all:
	#!/usr/bin/env bash
	# Ensure container is running
	if ! docker ps --format '{{"{{"}}.Names{{"}}"}}' | grep -q '^{{CONTAINER_NAME}}$'; then
		echo "Error: container {{CONTAINER_NAME}} is not running. Start it with: just docker-run-image"
		exit 1
	fi

	# Enable bash nullglob to handle case where *.qmd matches nothing
	shopt -s nullglob
	
	# PRIMARY WORKSHOP NOTEBOOKS (render in dependency order)
	# Earlier parts must render before later parts (later parts load data saved by earlier parts)
	# To extend workshop: Add new part QMDs to this array in sequential dependency order
	# Example: primary=(initial_survival_models.qmd expanded_coxph_models.qmd new_part3.qmd)
	primary=(initial_survival_models.qmd expanded_coxph_models.qmd)
	
	# Collect remaining QMD files (excluding primary and temp_* files)
	extra=()
	for f in *.qmd; do
		# Skip temp/experimental notebooks (often have missing data dependencies)
		# Pattern: temp_*.qmd files are work-in-progress and may fail
		if [[ "$f" == temp_* ]]; then
			continue
		fi
		# Skip if already in primary list (avoid duplicates)
		skip=0
		for p in "${primary[@]}"; do
			if [ "$f" = "$p" ]; then skip=1; break; fi
			done
		[ $skip -eq 0 ] && extra+=("$f")
	done

	# Build final render order: primary notebooks first (in dependency order), then extras
	qmd_files=("${primary[@]}" "${extra[@]}")
	if [ ${#qmd_files[@]} -eq 0 ]; then
		echo "Error: No .qmd files found in project root"
		exit 1
	fi

	# Render each file in order, failing fast on any error
	for file in "${qmd_files[@]}"; do
		echo "Rendering $file inside container {{CONTAINER_NAME}}..."
		docker exec -u {{DOCKER_USER}} -w /home/rstudio/{{PROJECT_FOLDER}} {{CONTAINER_NAME}} \
			quarto render "$file" --to html || exit 1
	done
	echo "✓ Rendered ${#qmd_files[@]} file(s) inside container"

# Render current workshop sequence inside the container (sequential)
# Convenience target that renders all primary notebooks in dependency order
# Equivalent to render-container-all but only renders primary notebooks (skips supplementary)
render-container-sequence:
	@just render-container initial_survival_models
	@just render-container expanded_coxph_models
	@echo "✓ Workshop sequence rendered inside container"

# --- Host Rendering (outside Docker container) ---
# NOTE: These targets require Quarto and R installed on the host system
# Most users should use render-container* targets instead to avoid host dependencies

# Render any QMD using Quarto on host (outside container)
# Useful for quick edits when Docker isn't running, but requires local Quarto installation
render-host file:
	#!/usr/bin/env bash
	# Pre-flight check: verify Quarto is available on host PATH
	# If not installed, guide user to container-based rendering instead
	if ! command -v quarto >/dev/null 2>&1; then
		echo "Error: Quarto not found on host PATH. Install Quarto or use 'just render-container {{file}}' to render inside Docker.";
		exit 1;
	fi
	# Auto-append .qmd extension if user didn't specify it
	qmd="{{file}}"
	if [[ "$qmd" != *.qmd ]]; then
		qmd="${qmd}.qmd"
	fi
	# Validate file exists before attempting render
	if [ ! -f "$qmd" ]; then
		echo "Error: $qmd not found in host project root"
		exit 1
	fi
	echo "Rendering $qmd on host..."
	quarto render "$qmd" --to html >> {{OUTPUT_LOG}} 2>&1 || exit 1
	echo "✓ Rendered $qmd on host"

# Render all QMDs on host (outside container)
render-host-all:
	@for file in *.qmd; do \
		echo "Rendering $$file on host..."; \
		quarto render "$$file" --to html >> {{OUTPUT_LOG}} 2>&1 || exit 1; \
		done

