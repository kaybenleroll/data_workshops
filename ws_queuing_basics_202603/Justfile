# =============================================================================
# PROJECT CONFIGURATION
# =============================================================================

# Docker image naming
PROJECT_USER    := "kaybenleroll"
PROJECT_NAME    := "ws_queuing_basics_202603"
PROJECT_TAG     := "latest"
IMAGE_TAG       := PROJECT_USER + "/" + PROJECT_NAME + ":" + PROJECT_TAG

# RStudio Server credentials
DOCKER_USER     := "rstudio"
DOCKER_PASS     := "CHANGEME"

# User/group mapping for file permissions in container
DOCKER_UID      := `id -u`
DOCKER_GID      := `id -g`

# Directory configuration
PWD             := `pwd`
RSTUDIO_PORT    := "8787"
PROJECT_FOLDER  := "queuing_workshop"
CONTAINER_NAME  := "queuing-workshop"

# Build and logging configuration
OUTPUT_LOG      := "quarto_render_output.log"
DOCKER_BUILD_ARGS := ""

# =============================================================================
# DEFAULT TARGET
# =============================================================================

default:
	@just --list

# =============================================================================
# RENDERING TARGETS
# =============================================================================

all: basics advanced

_needs_rebuild output *sources:
	#!/usr/bin/env bash
	mkdir -p .just-cache
	combined_hash=$(cat {{sources}} 2>/dev/null | md5sum | cut -d' ' -f1)
	cache_file=".just-cache/$(basename {{output}}).md5"
	if [ ! -f {{output}} ] || 
	   [ ! -f "$cache_file" ] || 
	   [ "$combined_hash" != "$(cat $cache_file 2>/dev/null)" ]; then
		echo "$combined_hash" > "$cache_file"
		exit 0
	else
		echo "$(basename {{output}}) is up to date"
		exit 1
	fi

_render-qmd qmd_file:
	#!/usr/bin/env bash
	qmd_file="{{qmd_file}}"
	html_file="${qmd_file%.qmd}.html"
	all_deps="$qmd_file lib_utils.R lib_queueing.R"
	if just _needs_rebuild "$html_file" $all_deps; then
		echo "TIMESTAMP: $(date) - Rendering $qmd_file" >> {{OUTPUT_LOG}} 2>&1
		quarto render "$qmd_file" --to html >> {{OUTPUT_LOG}} 2>&1
		echo "TIMESTAMP: $(date) - Finished $qmd_file" >> {{OUTPUT_LOG}} 2>&1
	fi

basics:
	@echo "▶ Rendering Queuing Theory Basics..."
	@just _render-qmd 01_queuing_basics.qmd
	@echo "✓ Basics complete"

advanced:
	@echo "▶ Rendering Advanced Queuing Theory..."
	@just _render-qmd 02_advanced_queuing.qmd
	@echo "✓ Advanced complete"

# Container Rendering
render-container file:
	#!/usr/bin/env bash
	qmd="{{file}}"
	if [[ "$qmd" != *.qmd ]]; then qmd="${qmd}.qmd"; fi
	if [ ! -f "$qmd" ]; then echo "Error: $qmd not found"; exit 1; fi
	podman exec -u {{DOCKER_USER}} -w /home/rstudio/{{PROJECT_FOLDER}} {{CONTAINER_NAME}} \
		quarto render "$qmd" --to html

render-container-all:
	@just render-container 01_queuing_basics
	@just render-container 02_advanced_queuing

# =============================================================================
# PODMAN TARGETS
# =============================================================================

podman-build-image:
	podman build -t {{IMAGE_TAG}} \
		--build-arg BUILD_DATE=`date -u +'%Y-%m-%dT%H:%M:%SZ'` \
		{{DOCKER_BUILD_ARGS}} \
		-f Dockerfile .

podman-rebuild-image:
	podman build --no-cache -t {{IMAGE_TAG}} \
		--build-arg BUILD_DATE=`date -u +'%Y-%m-%dT%H:%M:%SZ'` \
		{{DOCKER_BUILD_ARGS}} \
		-f Dockerfile .

podman-run-image:
	podman run --rm -d \
	  --userns=keep-id \
	  -e RUNROOTLESS=false \
	  -p "127.0.0.1:{{RSTUDIO_PORT}}:8787" \
	  -e USER={{DOCKER_USER}} \
	  -e PASSWORD={{DOCKER_PASS}} \
	  -e USERID={{DOCKER_UID}} \
	  -e GROUPID={{DOCKER_GID}} \
	  -v "{{PWD}}:/home/rstudio/{{PROJECT_FOLDER}}:z" \
	  -v "{{PWD}}/.rstudio_copilot:/home/rstudio/.config/github-copilot:rw" \
	  --name {{CONTAINER_NAME}} \
	  {{IMAGE_TAG}}

podman-stop-image:
	podman stop {{CONTAINER_NAME}} || true

podman-rm: podman-stop-image
	podman rm {{CONTAINER_NAME}} || true

podman-restart: podman-stop-image podman-run-image

podman-bash:
	podman exec -u {{DOCKER_USER}} -it {{CONTAINER_NAME}} bash

# =============================================================================
# CLEANING
# =============================================================================

clean-all:
	rm -fv *.html
	rm -rf *_cache/
	rm -rf *_files/
	rm -rf .just-cache/
	rm -rfv precompute/*.parquet precompute/*.qs
	rm -fv {{OUTPUT_LOG}}
